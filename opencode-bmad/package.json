{
  "name": "opencode-bmad",
  "version": "0.1.0",
  "description": "Standalone BMAD multi-agent plugin for OpenCode",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "bmad",
    "agents",
    "multi-agent"
  ],
  "files": [
    "dist",
    "src/skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.6",
    "@opencode-ai/sdk": "^1.2.6"
  },
  "devDependencies": {
    "bun-types": "1.3.9",
    "typescript": "^5.9.3"
  }
}
